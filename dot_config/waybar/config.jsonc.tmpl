{
  "position": "top",
  "margin": "8 8 0 8",
  "reload_style_on_change": true,
  "modules-left": [
    "hyprland/workspaces",
    "mpris"
  ],
  "modules-right": [
    "tray",
    {{- if eq .chezmoi.hostname "chris_laptop" }}
    "battery",
    {{- end }}
    "pulseaudio",
    "clock"
  ],
  "hyprland/workspaces": {
    "persistent-workspaces": {
      "*": 5
    }
  },
  "mpris": {
    "player": "tidal-hifi",
    "format": "{status} {dynamic}",
    "dynamic-order": ["title", "artist", "position", "length"],
    "status-icons": {
      "playing": "σΑêä",
      "paused": "σΑèΛ",
      "stopped": "σΑèΛ",
    },
  },
  "pulseaudio": {
    "format": "σΑïΨ {volume}",
    "format-muted": "σΑ•¹ {volume}",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pwvucontrol",
    "tooltip": false
  },
  "clock": {
    "format": "{:%I:%M %p}"
  },
  {{- if eq .chezmoi.hostname "chris_laptop" }}
  "battery": {
    "format": "{icon} {capacity}",
    "format-icons": [
      "σΑ¹Κ",
      "σΑ¹Μ",
      "σΑ¹Φ",
      "σΑ¹Ϋ",
      "σΑ¹Ψ",
      "σΑ¹Ω",
      "σΑ²Ä",
      "σΑ²¹",
      "σΑ²²",
      "σΑ¹Ι"
    ],
    "format-charging": "σΑ²³ {capacity}",
    "format-plugged": "σΑ²³ {capacity}"
  },
  {{- end }}
  "tray": {
    "spacing": 6,
    "reverse-direction": true
  }
}
