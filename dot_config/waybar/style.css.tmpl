@define-color font #D3C6AA;
@define-color font-dark #272E33;
@define-color font-empty-workspace #4F5B58;
@define-color bg #1E2326;
@define-color bg-light #2E383C;
@define-color bg-focused-workspace #A7C080;

* {
  border: none;
  border-radius: 0;
  font-family: "Mononoki Nerd Font Propo";
  font-size: 16px;
}

window#waybar {
  background: transparent;
}

#workspaces {
  padding: 4px 2px;
  background: @bg;
  border-radius: 4px;
}

#workspaces button {
  {{- if eq .chezmoi.hostname "pc" }}
  padding: 0 10px;
  {{- else if eq .chezmoi.hostname "chris_laptop" }}
  padding: 0 6px;
  {{- end }}
  margin: 0 2px;
  color: @font;
  border-radius: 3px;
}

#workspaces button.empty {
  color: @font-empty-workspace;
}

#workspaces button.active {
  color: @font-dark;
  background: @bg-focused-workspace;
}

#mpris {
  padding: 4px 10px;
  background: @bg;
  border-radius: 4px;
  color: @font;
  margin-left: 6px;
  border-radius: 4px;
  border: 2px solid @bg-light;
}

#pulseaudio {
  padding: 4px 10px;
  margin-right: 6px;
  color: @font;
  background: @bg;
  border-radius: 4px;
  border: 2px solid @bg-light;
}

#clock {
  padding: 4px 10px;
  margin: 0;
  color: @font;
  background: @bg;
  border-radius: 4px;
  border: 2px solid @bg-light;
}

#battery {
  padding: 4px 10px;
  margin-right: 6px;
  color: @font;
  background: @bg;
  border-radius: 4px;
  border: 2px solid @bg-light;
}

#tray {
  padding: 4px 10px;
  margin-right: 6px;
  background: @bg;
  color: @font;
  border: 2px solid @bg-light;
  border-radius: 4px;
}

#tray menu {
  background: @bg;
  color: @font;
}
